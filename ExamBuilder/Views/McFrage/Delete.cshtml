@model ExamBuilder.Models.McFrage

@{
    ViewData["Title"] = "Frage löschen";
}

<div class="mb-3">
    <a asp-action="Index" asp-route-kapitelId="@Model.KapitelId" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i> Kapitel
    </a>
</div>

<h2>Frage löschen</h2>
<hr />

<dl class="row mb-3">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Fragentext)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Fragentext)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Kapitel)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Kapitel.Titel)</dd>
</dl>

<div class="alert alert-danger">
    Sind Sie sicher, dass diese Frage und alle zugehörigen Antworten gelöscht werden sollen?
</div>

<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-danger">
            <i class="bi bi-trash"></i> Löschen
        </button>
        <a asp-action="Index" asp-route-kapitelId="@Model.KapitelId" class="btn btn-secondary">
            <i class="bi bi-x-lg"></i> Abbrechen
        </a>
    </div>
</form>
