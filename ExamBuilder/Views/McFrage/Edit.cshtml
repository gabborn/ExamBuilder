@model ExamBuilder.Models.McFrage

@{
    ViewData["Title"] = "Frage bearbeiten";
}

<div class="mb-3">
    <a asp-action="Index" asp-route-kapitelId="@Model.KapitelId" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i> MC-Fragen
    </a>
</div>

<h2>Frage bearbeiten</h2>
<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Edit" method="post">
            <input type="hidden" name="id" value="@Model.Id" />

            <div class="mb-3">
                <label class="form-label fw-bold">Fragetext</label>
                <input type="text" name="fragentext" value="@Model.Fragentext" class="form-control" required />
            </div>

            <label class="form-label fw-bold">Antwortoptionen</label>
            <p class="text-muted small">Wählen Sie mit dem Radio-Button die korrekte Antwort aus.</p>

            @for (int i = 0; i < Model.McAntworten.Count; i++)
            {
                var antwort = Model.McAntworten.ElementAt(i);
                <div class="input-group mb-2">
                    <div class="input-group-text">
                        <input type="radio" name="korrektAntwortId" value="@antwort.Id"
                               @(antwort.Korrekt ? "checked" : "") required />
                    </div>
                    <input type="hidden" name="antwortIds" value="@antwort.Id" />
                    <input type="text" name="antworttexte" value="@antwort.Antworttext" class="form-control" required />
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Speichern
                </button>
                <a asp-action="Index" asp-route-kapitelId="@Model.KapitelId" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
