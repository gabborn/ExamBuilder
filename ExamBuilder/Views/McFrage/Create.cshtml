@{
    ViewData["Title"] = "Frage anlegen";
}

<div class="mb-3">
    <a asp-action="Index" asp-route-kapitelId="@ViewBag.KapitelId" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i> MC-Fragen
    </a>
</div>

<h2>Frage anlegen</h2>
<hr />

<div class="row">
    <div class="col-md-7">
        <form asp-action="Create" method="post">
            <input type="hidden" name="kapitelId" value="@ViewBag.KapitelId" />

            <div class="mb-3">
                <label class="form-label fw-bold">Fragetext</label>
                <input type="text" name="fragentext" class="form-control" required />
            </div>

            <label class="form-label fw-bold">Antwortoptionen</label>
            <p class="text-muted small">Wählen Sie mit dem Radio-Button die korrekte Antwort aus.</p>

            @for (int i = 0; i < 4; i++)
            {
                <div class="input-group mb-2">
                    <div class="input-group-text">
                        <input type="radio" name="korrektIndex" value="@i" required />
                    </div>
                    <input type="text" name="antworttexte" class="form-control" placeholder="Antwort @(i + 1)" required />
                </div>
            }

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Speichern
                </button>
                <a asp-action="Index" asp-route-kapitelId="@ViewBag.KapitelId" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
