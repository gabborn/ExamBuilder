@model ExamBuilder.Models.Lehrveranstaltung

@{
    ViewData["Title"] = "Neue Lehrveranstaltung";
}

<h2>Neue Lehrveranstaltung</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <div class="mb-3">
                <label asp-for="Titel" class="form-label"></label>
                <input asp-for="Titel" class="form-control" />
                <span asp-validation-for="Titel" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Dozentenname" class="form-label"></label>
                <input asp-for="Dozentenname" class="form-control" />
                <span asp-validation-for="Dozentenname" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Abschlussart" class="form-label"></label>
                <select asp-for="Abschlussart" asp-items="ViewBag.AbschlussartList" class="form-select">
                    <option value="">-- Bitte wählen --</option>
                </select>
                <span asp-validation-for="Abschlussart" class="text-danger"></span>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Speichern
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
