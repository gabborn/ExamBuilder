@model IEnumerable<ExamBuilder.Models.Kapitel>
@using ExamBuilder.Models

@{
    ViewData["Title"] = "Kapitel";
    var lv = ViewBag.Lehrveranstaltung as Lehrveranstaltung;
}

<div class="mb-3">
    <a asp-controller="Lehrveranstaltung" asp-action="Index" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i> Lehrveranstaltungen
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title">@lv?.Titel</h5>
        <p class="card-text mb-0">
            <span class="text-muted">Dozent:</span> @lv?.Dozentenname &nbsp;|&nbsp;
            <span class="text-muted">Abschluss:</span> @lv?.Abschlussart
        </p>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4>Kapitel</h4>
    <a asp-action="Create" asp-route-lehrveranstaltungId="@lv?.Id" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Neues Kapitel
    </a>
</div>

<table class="table table-hover">
    <thead>
        <tr>
            <th>Nr.</th>
            <th>Titel</th>
            <th>Vorlesungsfolien</th>
            <th>MC-Fragen</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var kapitel in Model)
        {
            <tr>
                <td>@kapitel.Kapitelnummer</td>
                <td>@kapitel.Titel</td>
                <td>
                    @if (!string.IsNullOrEmpty(kapitel.Vorlesungsfolien))
                    {
                        <a asp-action="Download" asp-route-id="@kapitel.Id" target="_blank" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-file-earmark-pdf"></i> Folien öffnen
                        </a>
                    }
                </td>
                <td>
                    <a asp-controller="McFrage" asp-action="Index" asp-route-kapitelId="@kapitel.Id"
                       class="badge bg-primary text-decoration-none">
                        @kapitel.McFragen.Count MC-Fragen
                    </a>
                </td>
                <td class="text-end">
                    <div class="btn-group">
                        <a asp-action="Edit" asp-route-id="@kapitel.Id" class="btn btn-sm btn-outline-primary" title="Bearbeiten">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a asp-action="Delete" asp-route-id="@kapitel.Id" class="btn btn-sm btn-outline-danger" title="Löschen">
                            <i class="bi bi-trash"></i>
                        </a>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
