@model ExamBuilder.Models.Kapitel

@{
    ViewData["Title"] = "Kapitel bearbeiten";
}

<div class="mb-3">
    <a asp-action="Index" asp-route-lehrveranstaltungId="@Model.LehrveranstaltungId" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i> Kapitel
    </a>
</div>

<h2>Kapitel bearbeiten</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="LehrveranstaltungId" />
            <input type="hidden" asp-for="Vorlesungsfolien" />
            <div class="mb-3">
                <label asp-for="Titel" class="form-label"></label>
                <input asp-for="Titel" class="form-control" />
                <span asp-validation-for="Titel" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Kapitelnummer" class="form-label"></label>
                <input asp-for="Kapitelnummer" class="form-control" />
                <span asp-validation-for="Kapitelnummer" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Vorlesungsfolien</label>
                @if (!string.IsNullOrEmpty(Model.Vorlesungsfolien))
                {
                    <div class="d-flex align-items-center gap-2 mb-2">
                        <a asp-action="Download" asp-route-id="@Model.Id" target="_blank" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-file-earmark-pdf"></i> Folien öffnen
                        </a>
                        <button type="submit" name="dateiLoeschen" value="true" class="btn btn-sm btn-outline-danger">
                            <i class="bi bi-trash"></i> Datei löschen
                        </button>
                    </div>
                }
                else
                {
                    <input type="file" name="datei" class="form-control" accept=".pdf" />
                }
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Speichern
                </button>
                <a asp-action="Index" asp-route-lehrveranstaltungId="@Model.LehrveranstaltungId" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
