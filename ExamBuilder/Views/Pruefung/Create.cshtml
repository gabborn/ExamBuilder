@model ExamBuilder.Models.Pruefung

@{
    ViewData["Title"] = "Neue Prüfung erstellen";
}

<div class="mb-3">
    <a asp-action="Index" asp-route-lehrveranstaltungId="@ViewBag.LehrveranstaltungId" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i> Prüfungen
    </a>
</div>

<h2>Neue Prüfung erstellen</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" name="LehrveranstaltungId" value="@ViewBag.LehrveranstaltungId" />
            <div class="mb-3">
                <label asp-for="Titel" class="form-label"></label>
                <input asp-for="Titel" class="form-control" />
                <span asp-validation-for="Titel" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Datum" class="form-label"></label>
                <input asp-for="Datum" type="date" class="form-control" />
                <span asp-validation-for="Datum" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Beschreibung" class="form-label"></label>
                <textarea asp-for="Beschreibung" class="form-control" rows="3"></textarea>
            </div>
            <div class="mb-3">
                <label class="form-label">Anzahl Fragen</label>
                <input type="number" name="anzahlFragen" min="1" class="form-control" required />
                <div class="form-text">Fragen werden zufällig aus dem Fragenpool der Lehrveranstaltung ausgewählt.</div>
            </div>
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-lg"></i> Speichern
                </button>
                <a asp-action="Index" asp-route-lehrveranstaltungId="@ViewBag.LehrveranstaltungId" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Abbrechen
                </a>
            </div>
        </form>
    </div>
</div>
