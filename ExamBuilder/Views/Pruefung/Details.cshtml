@model ExamBuilder.Models.Pruefung

@{
    ViewData["Title"] = Model.Titel;
}

<div class="mb-3">
    <a asp-action="Index" asp-route-lehrveranstaltungId="@Model.LehrveranstaltungId" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left"></i> Prüfungen
    </a>
</div>

<div class="d-flex justify-content-between align-items-center mb-2">
    <h2>@Model.Titel</h2>
    <a asp-action="Drucken" asp-route-id="@Model.Id" target="_blank" class="btn btn-outline-secondary">
        <i class="bi bi-printer"></i> Drucken
    </a>
</div>
<p class="text-muted mb-4">
    <strong>Lehrveranstaltung:</strong> @Model.Lehrveranstaltung?.Titel &nbsp;|&nbsp;
    <strong>Datum:</strong> @Model.Datum.ToString("dd.MM.yyyy")
</p>

<hr />

@for (int i = 0; i < Model.McFragen.Count; i++)
{
    var frage = Model.McFragen.ElementAt(i);
    <div class="mb-4">
        <p class="fw-bold">@(i + 1). @frage.Fragentext</p>
        <ul class="list-group">
            @foreach (var antwort in frage.McAntworten)
            {
                if (antwort.Korrekt)
                {
                    <li class="list-group-item list-group-item-success d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle-fill text-success"></i> @antwort.Antworttext
                    </li>
                }
                else
                {
                    <li class="list-group-item">@antwort.Antworttext</li>
                }
            }
        </ul>
    </div>
}
